// COMMENT NEXT LINE IF YOU WANT TO USE GPRS, UNCOMMENT IF YOU WANT TO USE WIFI
// #define USE_WIFI

// COMMENT NEXT LINE TO DISABLE TLS ENCRYPTION ON THE MQTT CONNECTION
// When enabled, the firmware connects to the broker using TLS (encrypted).
// When disabled, the connection is unencrypted (plain TCP, port 1883).
#define USE_TLS

// UNCOMMENT THE LINE CORRESPONDING TO YOUR CELLULAR MODEM
// (If using PlatformIO, leave both commented out — the modem type is set via
//  build_flags in platformio.ini for each build environment.)
// #define TINY_GSM_MODEM_SIM800   // If you are using a T-Call board
// #define TINY_GSM_MODEM_SIM7600  // If you are using a T-PCIE board with a SIM7600 module

// WiFi details
const char* ssid = "YourWiFiNetworkName"; // WiFi Network Name (SSID)
const char* password = "YourWiFiPassword"; // WiFi Network Password

// MQTT Broker Details
const char* mqttServer = "broker.emqx.io";
const int mqttPort = 8883; // TLS port
const char* mqttUser = "your_mqtt_username";
const char* mqttPassword = "your_mqtt_password";
const char* mqttUplinkTopic = "bulletgcss/telem/your_callsign"; // Telemetry topic — firmware publishes here, UI subscribes
const char* mqttDownlinkTopic = "bulletgcss/cmd/your_callsign"; // Command topic — UI publishes here, firmware subscribes

// set GSM PIN, if any
#define GSM_PIN ""

// Your GPRS credentials, if any
const char apn[] = "your.apn.address";
const char gprsUser[] = "";
const char gprsPass[] = "";

// SIM card PIN (leave empty, if not defined)
const char simPIN[] = "";

// Pooling settings
#define MESSAGE_SEND_INTERVAL         1000  // milliseconds
#define TELEMETRY_FETCH_DUTY_CYCLE    200   // Time (in milliseconds) that takes to fetch the telemetry data
#define LOW_PRIORITY_MESSAGE_INTERVAL 60    // seconds
#define HOME_POINT_FETCH_INTERVAL     10    // how many iterations to fetch the home point from FC
#define WP_MISSION_MESSAGE_INTERVAL   30    // how many iterations to fetch the WP mission from FC
